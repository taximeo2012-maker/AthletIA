{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific data like preferences and Strava tokens.",
      "type": "object",
      "properties": {
        "stravaToken": { "type": "string" },
        "stravaRefreshToken": { "type": "string" },
        "stravaExpiresAt": { "type": "number" },
        "aiTone": { "type": "string", "enum": ["encouraging", "direct", "humorous"], "description": "Preferred tone for the AI coach." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Activity": {
      "title": "Sport Activity",
      "description": "A sport activity either from Strava or manual entry.",
      "type": "object",
      "properties": {
        "stravaId": { "type": "string" },
        "name": { "type": "string" },
        "sportType": { "type": "string" },
        "distance": { "type": "number" },
        "duration": { "type": "number" },
        "speed": { "type": "number" },
        "calories": { "type": "number" },
        "heartRate": { "type": "number" },
        "source": { "type": "string", "enum": ["strava", "manual"] },
        "recordedAt": { "type": "string", "format": "date-time" },
        "intensity": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["name", "sportType", "source", "recordedAt"]
    },
    "Meal": {
      "title": "Log of a meal",
      "description": "A meal recorded by the user, analyzed by AI.",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "calories": { "type": "number" },
        "proteins": { "type": "number" },
        "carbs": { "type": "number" },
        "fats": { "type": "number" },
        "weightInGrams": { "type": "number" },
        "recordedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["recordedAt"]
    },
    "ChatMessage": {
      "title": "AI Coach Chat Message",
      "description": "Message log between the AI coach and the user.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model", "system"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "text", "createdAt"]
    },
    "Badge": {
      "title": "Achievement Badge",
      "description": "User achievements for motivation.",
      "type": "object",
      "properties": {
        "badgeId": { "type": "string" },
        "label": { "type": "string" },
        "icon": { "type": "string" },
        "unlockedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["badgeId", "label", "icon", "unlockedAt"]
    },
    "TrainingProgram": {
      "title": "AI Training Program",
      "description": "A generated multi-week training plan.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "goal": { "type": "string" },
        "duration": { "type": "number" },
        "durationUnit": { "type": "string", "enum": ["days", "weeks"] },
        "weeksJson": { "type": "string", "description": "JSON string of the program structure" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "goal", "weeksJson", "createdAt"]
    },
    "Recipe": {
      "title": "AI Generated Recipe",
      "description": "Custom recipes proposed by the coach.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "ingredients": { "type": "string" },
        "instructions": { "type": "string" },
        "calories": { "type": "number" },
        "reason": { "type": "string", "description": "Why this recipe was proposed." },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ShoppingList": {
      "title": "Smart Shopping List",
      "description": "Weekly shopping list derived from training plans.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "items": { "type": "string", "description": "Markdown list of items by category." },
        "nutritionalInfo": { "type": "string", "description": "Nutritional benefits and advice." },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile document."
    },
    "/users/{userId}/activities/{activityId}": {
      "schema": { "$ref": "#/entities/Activity" },
      "description": "User's sport activities."
    },
    "/users/{userId}/meals/{mealId}": {
      "schema": { "$ref": "#/entities/Meal" },
      "description": "User's recorded meals."
    },
    "/users/{userId}/chatHistory/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Chat log between user and AI."
    },
    "/users/{userId}/badges/{badgeId}": {
      "schema": { "$ref": "#/entities/Badge" },
      "description": "Unlocked achievements."
    },
    "/users/{userId}/trainingPrograms/{programId}": {
      "schema": { "$ref": "#/entities/TrainingProgram" },
      "description": "Generated training plans."
    },
    "/users/{userId}/recipes/{recipeId}": {
      "schema": { "$ref": "#/entities/Recipe" },
      "description": "Proposed recipes."
    },
    "/users/{userId}/shoppingLists/{listId}": {
      "schema": { "$ref": "#/entities/ShoppingList" },
      "description": "Smart shopping lists."
    }
  }
}
